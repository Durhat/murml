# Backend
#   local  : faster-whisper, offline
#   groq   : Groq API (sehr schnell, Free-Tier verfügbar)
#   openai : OpenAI Whisper API
MURML_BACKEND=local

# Lokales Modell: tiny | base | small | medium | large-v3
MURML_MODEL=small

# Quantisierung des lokalen Modells: int8 | int8_float16 | float16 | float32
MURML_COMPUTE_TYPE=int8

# Sprache. Leer = Auto-Detect.
MURML_LANGUAGE=de

# Beam-Width.
MURML_BEAM_SIZE=5

# Optionaler Vokabel-Hinweis fürs Modell (Eigennamen, Fachbegriffe).
MURML_INITIAL_PROMPT=

MURML_SAMPLE_RATE=16000

# Hotkey: fn (Globe-Taste) | ralt (rechte Option-Taste).
MURML_HOTKEY=fn
MURML_TAP_THRESHOLD_MS=250
MURML_EMOJI_ON_TAP=on

# Auto-Stop nach so vielen Sekunden. 0 = aus.
MURML_MAX_RECORD_SECONDS=0

# Verlauf
MURML_HISTORY_MAX=50

# Sounds (Datei-Namen ohne Endung; gesucht in ./sounds/, dann /System/Library/Sounds/).
MURML_SOUNDS=on
MURML_SOUND_START=start
MURML_SOUND_STOP=stop
MURML_SOUND_DONE=done
MURML_SOUND_ERROR=error
MURML_SOUND_START_VOL=0.4
MURML_SOUND_STOP_VOL=0.4
MURML_SOUND_DONE_VOL=0.25
MURML_SOUND_ERROR_VOL=0.4

# API-Keys
OPENAI_API_KEY=
GROQ_API_KEY=
MURML_OPENAI_MODEL=whisper-1
MURML_GROQ_MODEL=whisper-large-v3-turbo
